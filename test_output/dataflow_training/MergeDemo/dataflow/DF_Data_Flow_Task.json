                }
            ],
            "sinks": [
                {
                    "name": "Excel_Destination",
                    "description": "Sink from SSIS ExcelDestination: Excel Destination",
                    "dataset": {
                        "referenceName": "DS_Excel_Destination",
                        "type": "DatasetReference"
                    },
                    "linkedService": {
                        "referenceName": "LS_D563AF33-2308-41C8-8FAE-D9F525D7F5C9",
                        "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                        "format": {
                            "type": "Excel"
                        },
                        "allowUpsert": false,
                        "tableName": "Excel_Destination"
                    }
                }
            ],
            "transformations": [
                {
                    "name": "Merge",
                    "description": "SSIS Merge: Merge [SSIS Merge — inputs must be pre-sorted]",
                    "type": "Union",
                    "typeProperties": {}
                },
                {
                    "name": "Sort",
                    "description": "SSIS Sort: Sort",
                    "type": "Sort",
                    "typeProperties": {
                        "sortConditions": [
                            {
                                "column": "CountryRegionCode",
                                "order": "asc"
                            }
                        ],
                        "caseSensitive": false
                    }
                },
                {
                    "name": "Sort_1",
                    "description": "SSIS Sort: Sort 1",
                    "type": "Sort",
                    "typeProperties": {
                        "sortConditions": [
                            {
                                "column": "CountryRegionCode",
                                "order": "asc"
                            }
                        ],
                        "caseSensitive": false
                    }
                }
            ],
            "script": "source(output(\n        StateProvinceID as integer,\n        StateProvinceCode as string,\n        CountryRegionCode as string,\n        Name as string,\n        TerritoryID as integer\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source\nsource(output(\n        StateProvinceID as integer,\n        StateProvinceCode as string,\n        CountryRegionCode as string,\n        Name as string,\n        TerritoryID as integer\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source_1\nOLE_DB_Source_1 union(byName: true) ~> Merge\nMerge sort(asc(CountryRegionCode)) ~> Sort\nSort sort(asc(CountryRegionCode)) ~> Sort_1\nSort_1 select(mapColumn(\n        StateProvinceID, StateProvinceCode, CountryRegionCode, Name, TerritoryID\n    )) ~> Excel_Destination_mapped\nExcel_Destination_mapped sink(allowSchemaDrift: true,\n    validateSchema: false,\n    errorHandlingOption: 'stopOnFirstError',\n    deletable: false,\n    insertable: true,\n    updateable: false,\n    upsertable: false) ~> Excel_Destination",
            "scriptLines": [
                "source(output(",
                "        StateProvinceID as integer,",
                "        StateProvinceCode as string,",
                "        CountryRegionCode as string,",
                "        Name as string,",
                "        TerritoryID as integer",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source",
                "source(output(",
                "        StateProvinceID as integer,",
                "        StateProvinceCode as string,",
                "        CountryRegionCode as string,",
                "        Name as string,",
                "        TerritoryID as integer",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source_1",
                "OLE_DB_Source_1 union(byName: true) ~> Merge",
                "Merge sort(asc(CountryRegionCode)) ~> Sort",
                "Sort sort(asc(CountryRegionCode)) ~> Sort_1",
                "Sort_1 select(mapColumn(",
                "        StateProvinceID, StateProvinceCode, CountryRegionCode, Name, TerritoryID",
                "    )) ~> Excel_Destination_mapped",
                "Excel_Destination_mapped sink(allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    errorHandlingOption: 'stopOnFirstError',",
                "    deletable: false,",
                "    insertable: true,",
                "    updateable: false,",
                "    upsertable: false) ~> Excel_Destination"
            ]
        },
        "annotations": [
            "ssis-adf-agent"
        ]
    }
