            "script": "source(output(\n        StateProvinceID as integer,\n        StateProvinceCode as string,\n        CountryRegionCode as string,\n        Name as string,\n        TerritoryID as integer\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source\nsource(output(\n        StateProvinceID as integer,\n        StateProvinceCode as string,\n        CountryRegionCode as string,\n        Name as string,\n        TerritoryID as integer\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source_1\nOLE_DB_Source_1 union(byName: true) ~> Union_All\nUnion_All select(mapColumn(\n        StateProvinceID, StateProvinceCode, CountryRegionCode, Name, TerritoryID\n    )) ~> Flat_File_Destination_mapped\nFlat_File_Destination_mapped sink(allowSchemaDrift: true,\n    validateSchema: false,\n    errorHandlingOption: 'stopOnFirstError',\n    deletable: false,\n    insertable: true,\n    updateable: false,\n    upsertable: false) ~> Flat_File_Destination",
            "scriptLines": [
