{
    "name": "DF_Data_Flow_Task",
    "properties": {
        "description": "Mapping Data Flow for SSIS Data Flow Task: Data Flow Task",
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "name": "OLE_DB_Source",
                    "description": "Source from SSIS OleDbSource: OLE DB Source",
                    "dataset": {
                        "referenceName": "DS_OLE_DB_Source",
                        "type": "DatasetReference"
                    },
                    "linkedService": {
                        "referenceName": "LS_04AB7BF4-0A8F-43CF-A1EB-09FE675BD217",
                        "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                        "format": {
                            "type": "AzureSqlTable"
                        },
                        "query": "[Person].[StateProvince]"
                    }
                }
            ],
            "sinks": [
                {
                    "name": "Flat_File_Destination",
                    "description": "Sink from SSIS FlatFileDestination: Flat File Destination",
                    "dataset": {
                        "referenceName": "DS_Flat_File_Destination",
                        "type": "DatasetReference"
                    },
                    "linkedService": {
                        "referenceName": "LS_43F97333-1CFA-420F-83B6-77230249ECC2",
                        "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                        "format": {
                            "type": "DelimitedText"
                        },
                        "allowUpsert": false
                    }
                }
            ],
            "transformations": [
                {
                    "name": "Sort",
                    "description": "SSIS Sort: Sort",
                    "type": "Sort",
                    "typeProperties": {
                        "sortConditions": [
                            {
                                "column": "CountryRegionCode",
                                "order": "asc"
                            },
                            {
                                "column": "StateProvinceCode",
                                "order": "desc"
                            },
                            {
                                "column": "Name",
                                "order": "asc"
                            }
                        ],
                        "caseSensitive": false
                    }
                }
            ],
            "script": "source(output(\n        StateProvinceID as integer,\n        StateProvinceCode as string,\n        CountryRegionCode as string,\n        Name as string,\n        TerritoryID as integer\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source\nOLE_DB_Source sort(asc(CountryRegionCode), desc(StateProvinceCode), asc(Name)) ~> Sort\nSort select(mapColumn(\n        StateProvinceID, StateProvinceCode, CountryRegionCode, Name, TerritoryID\n    )) ~> Flat_File_Destination_mapped\nFlat_File_Destination_mapped sink(allowSchemaDrift: true,\n    validateSchema: false,\n    errorHandlingOption: 'stopOnFirstError',\n    deletable: false,\n    insertable: true,\n    updateable: false,\n    upsertable: false) ~> Flat_File_Destination",
            "scriptLines": [
                "source(output(",
                "        StateProvinceID as integer,",
                "        StateProvinceCode as string,",
                "        CountryRegionCode as string,",
                "        Name as string,",
                "        TerritoryID as integer",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> OLE_DB_Source",
                "OLE_DB_Source sort(asc(CountryRegionCode), desc(StateProvinceCode), asc(Name)) ~> Sort",
                "Sort select(mapColumn(",
                "        StateProvinceID, StateProvinceCode, CountryRegionCode, Name, TerritoryID",
                "    )) ~> Flat_File_Destination_mapped",
                "Flat_File_Destination_mapped sink(allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    errorHandlingOption: 'stopOnFirstError',",
                "    deletable: false,",
                "    insertable: true,",
                "    updateable: false,",
                "    upsertable: false) ~> Flat_File_Destination"
            ]
        },
        "annotations": [
            "ssis-adf-agent"
        ]
    }
}