                    }
                },
                {
                    "name": "Sort_1",
                    "description": "SSIS Sort: Sort 1",
                    "type": "Sort",
                    "typeProperties": {
                        "sortConditions": [
                            {
                                "column": "SalesOrderID",
                                "order": "asc"
                            }
                        ],
                        "caseSensitive": false
                    }
                }
            ],
            "script": "source(output(\n        SalesOrderID as integer,\n        SalesOrderDetailID as integer,\n        OrderQty as short,\n        ProductID as integer,\n        LineTotal as decimal\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> Sales_Order_Details\nsource(output(\n        SalesOrderID as integer,\n        OrderDate as timestamp,\n        DueDate as timestamp,\n        ShipDate as timestamp,\n        SalesOrderNumber as string\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> Sales_Order_Head\nSales_Order_Head join(SalesOrderID == SalesOrderID,\n    joinType: '2') ~> Merge_Join\nMerge_Join sort(asc(SalesOrderID)) ~> Sort\nSort sort(asc(SalesOrderID)) ~> Sort_1\nSort_1 select(mapColumn(\n        SalesOrderID, OrderDate, DueDate, ShipDate, SalesOrderNumber, SalesOrderDetailID, OrderQty, ProductID, LineTotal\n    )) ~> Excel_Destination_mapped\nExcel_Destination_mapped sink(allowSchemaDrift: true,\n    validateSchema: false,\n    errorHandlingOption: 'stopOnFirstError',\n    deletable: false,\n    insertable: true,\n    updateable: false,\n    upsertable: false) ~> Excel_Destination",
            "scriptLines": [
                "source(output(",
                "        SalesOrderID as integer,",
                "        SalesOrderDetailID as integer,",
                "        OrderQty as short,",
                "        ProductID as integer,",
                "        LineTotal as decimal",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> Sales_Order_Details",
                "source(output(",
                "        SalesOrderID as integer,",
                "        OrderDate as timestamp,",
                "        DueDate as timestamp,",
                "        ShipDate as timestamp,",
                "        SalesOrderNumber as string",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> Sales_Order_Head",
                "Sales_Order_Head join(SalesOrderID == SalesOrderID,",
                "    joinType: '2') ~> Merge_Join",
                "Merge_Join sort(asc(SalesOrderID)) ~> Sort",
                "Sort sort(asc(SalesOrderID)) ~> Sort_1",
                "Sort_1 select(mapColumn(",
                "        SalesOrderID, OrderDate, DueDate, ShipDate, SalesOrderNumber, SalesOrderDetailID, OrderQty, ProductID, LineTotal",
                "    )) ~> Excel_Destination_mapped",
                "Excel_Destination_mapped sink(allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    errorHandlingOption: 'stopOnFirstError',",
                "    deletable: false,",
                "    insertable: true,",
                "    updateable: false,",
                "    upsertable: false) ~> Excel_Destination"
            ]
        },
        "annotations": [
            "ssis-adf-agent"
        ]
    }
