{
    "name": "DF_Data_Flow_Task",
    "properties": {
        "description": "Mapping Data Flow for SSIS Data Flow Task: Data Flow Task",
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "name": "Flat_File_Source",
                    "description": "Source from SSIS FlatFileSource: Flat File Source",
                    "dataset": {
                        "referenceName": "DS_Flat_File_Source",
                        "type": "DatasetReference"
                    },
                    "linkedService": {
                        "referenceName": "LS_06B6B624-F9C2-49A7-962B-628C52063986",
                        "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                        "format": {
                            "type": "DelimitedText"
                        }
                    }
                }
            ],
            "sinks": [
                {
                    "name": "OLE_DB_Destination",
                    "description": "Sink from SSIS OleDbDestination: OLE DB Destination",
                    "dataset": {
                        "referenceName": "DS_OLE_DB_Destination",
                        "type": "DatasetReference"
                    },
                    "linkedService": {
                        "referenceName": "LS_1D08C51A-3FA2-4A28-BEA0-C60CE4808411",
                        "type": "LinkedServiceReference"
                    },
                    "typeProperties": {
                        "format": {
                            "type": "AzureSqlTable"
                        },
                        "allowUpsert": false,
                        "tableName": "[dbo].[Employees]"
                    }
                }
            ],
            "transformations": [
                {
                    "name": "Fuzzy_Lookup",
                    "description": "[UNSUPPORTED — FuzzyLookup] Manual implementation required. This component has no ADF Mapping Data Flow equivalent.",
                    "type": "Wait",
                    "typeProperties": {}
                },
                {
                    "name": "Lookup",
                    "description": "SSIS Lookup: Lookup",
                    "type": "Lookup",
                    "typeProperties": {
                        "lookupTable": {
                            "referenceName": "DS_Lookup_lookup",
                            "type": "DatasetReference"
                        },
                        "existsOrNotExists": "exists",
                        "matchMultipleRows": false,
                        "conditions": [
                            {
                                "leftColumn": "TITLE",
                                "rightColumn": "OccupationTitle"
                            }
                        ]
                    }
                },
                {
                    "name": "Union_All",
                    "description": "SSIS UnionAll: Union All",
                    "type": "Union",
                    "typeProperties": {}
                }
            ],
            "script": "source(output(\n        LASTNAME as string,\n        FIRSTNAME as string,\n        TITLE as string\n    ),\n    allowSchemaDrift: true,\n    validateSchema: false,\n    isolationLevel: 'READ_UNCOMMITTED',\n    errorHandlingOption: 'stopOnFirstError') ~> Flat_File_Source\nFlat_File_Source derive(/* TODO: Wait */) ~> Fuzzy_Lookup\nFuzzy_Lookup, lookup(TITLE == OccupationTitle) ~> Lookup\nLookup union(byName: true) ~> Union_All\nUnion_All select(mapColumn(\n        LASTNAME, FIRSTNAME, OccupationTitle, OccupationId\n    )) ~> OLE_DB_Destination_mapped\nOLE_DB_Destination_mapped sink(allowSchemaDrift: true,\n    validateSchema: false,\n    errorHandlingOption: 'stopOnFirstError',\n    deletable: false,\n    insertable: true,\n    updateable: false,\n    upsertable: false) ~> OLE_DB_Destination",
            "scriptLines": [
                "source(output(",
                "        LASTNAME as string,",
                "        FIRSTNAME as string,",
                "        TITLE as string",
                "    ),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    isolationLevel: 'READ_UNCOMMITTED',",
                "    errorHandlingOption: 'stopOnFirstError') ~> Flat_File_Source",
                "Flat_File_Source derive(/* TODO: Wait */) ~> Fuzzy_Lookup",
                "Fuzzy_Lookup, lookup(TITLE == OccupationTitle) ~> Lookup",
                "Lookup union(byName: true) ~> Union_All",
                "Union_All select(mapColumn(",
                "        LASTNAME, FIRSTNAME, OccupationTitle, OccupationId",
                "    )) ~> OLE_DB_Destination_mapped",
                "OLE_DB_Destination_mapped sink(allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    errorHandlingOption: 'stopOnFirstError',",
                "    deletable: false,",
                "    insertable: true,",
                "    updateable: false,",
                "    upsertable: false) ~> OLE_DB_Destination"
            ]
        },
        "annotations": [
            "ssis-adf-agent"
        ]
    }
}